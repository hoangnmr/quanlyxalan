# Environment variables configuration example
# Copy this to .env and change values accordingly

# PostgreSQL connection URL
DATABASE_URL=postgresql+psycopg://localhost/cangvu

# JWT Signing Secret (must be changed in production)
SECRET_KEY=generate-a-secure-secret-key-at-least-32-characters-long

# Access token lifetime in minutes (default is 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Allowed CORS origins, comma-separated (no trailing slash)
ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Object storage: LOCAL for pilot, MINIO only when all values below are supplied.
OBJECT_STORAGE_MODE=LOCAL
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=true

# Public base URL of the app (used in notification email links).
APP_BASE_URL=http://127.0.0.1:8080

# Email notifications (SMTP). Leave SMTP_ENABLED=false to disable entirely —
# the app then never sends email and never errors. Set to true and fill the
# values below to enable. Passwords/keys must NOT be committed to the repo.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Zalo notifications (ZNS) — DISABLED scaffold, do not enable yet.
# A ZNS template is created by the business in Zalo Cloud Account and must be
# APPROVED by Zalo before use; fill token + template id after approval.
ZALO_ENABLED=false
ZALO_OA_TOKEN=
ZALO_TEMPLATE_ID=
ZALO_BASE_URL=

# To run tests, the pytest suite will automatically configure TEST_DATABASE_URL
# (a dedicated PostgreSQL database per test module).
